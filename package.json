{
  "name": "turtlelootline-companion",
  "version": "1.2.8",
  "productName": "TurtleLootLine Companion",
  "description": "Desktop companion for TurtleLootLine - syncs WoW gear data",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "node scripts/patch-electron-plist.js",
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --mac",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "release": "npm version patch --no-git-tag-version && electron-builder --win --mac --publish always && node scripts/release-tag.js",
    "release:minor": "npm version minor --no-git-tag-version && electron-builder --win --mac --publish always && node scripts/release-tag.js",
    "release:major": "npm version major --no-git-tag-version && electron-builder --win --mac --publish always && node scripts/release-tag.js",
    "release:win": "npm version patch --no-git-tag-version && electron-builder --win --publish always",
    "release:mac": "npm version patch --no-git-tag-version && electron-builder --mac --publish always"
  },
  "keywords": [
    "turtle-wow",
    "gearscore",
    "electron"
  ],
  "author": "Ronni",
  "license": "MIT",
  "dependencies": {
    "auto-launch": "^5.0.6",
    "chokidar": "^3.5.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.turtlelootline.companion",
    "productName": "TurtleLootLine Companion",
    "publish": [
      {
        "provider": "github",
        "owner": "Baslund-Research",
        "repo": "turtlelootline-desktop-companion"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "ui/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  }
}
